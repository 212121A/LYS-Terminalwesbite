{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --config.minimum-release-age=0",
  "buildCommand": "pnpm run build:vercel",
  "outputDirectory": "artifacts/lys-terminal/dist/public",
  "framework": null,
  "functions": {
    "api/[...path].mjs": {
      "includeFiles": "artifacts/api-server/dist/**"
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
