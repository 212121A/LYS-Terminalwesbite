# =============================================================================
# LYS Terminal — Umgebungsvariablen (analog LYS Website)
# In Vercel: Project → Settings → Environment Variables (Production + Preview).
# Nach Änderungen: Redeploy. Geheime Keys niemals ins Git committen.
#
# Vercel-Projekt (wichtig):
# - Root Directory: leer (= Repo-Root), damit ./api/index.mjs und ./vercel.json greifen.
# - Build Command: npm run build:vercel (oder leer lassen, steht in vercel.json).
# - Output Directory: public (wie in vercel.json).
# =============================================================================

# --- Stripe (Server) ---
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY
# Stripe Dashboard → Webhooks → Endpoint:
# https://lys-terminal-bestellseite.vercel.app/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET

# --- Öffentliche Web-Origin (Redirect success/cancel; zusätzlich sind *.vercel.app mit lys-terminal-bestellseite erlaubt) ---
# Exakter Name in Vercel: PUBLIC_WEB_ORIGIN (nicht PUBLIC_WEB_ORIG_ORIGIN).
# Eigene Domain oder Production-URL ohne trailing slash:
PUBLIC_WEB_ORIGIN=https://lys-terminal-bestellseite.vercel.app

# --- Supabase (Server: Service Role für pending_orders) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# --- Supabase (Frontend Vite: Success-Seite / Polling, nur Anon) ---
VITE_SUPABASE_URL=https://your-project.supabase.co

VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY


# --- API (optional: nur wenn Frontend und API unterschiedliche Origins haben) ---
# VITE_API_BASE_URL=

# --- Lokal: Express ---
PORT=3000
